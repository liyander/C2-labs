#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

if [[ ! -f ./scripts/start-all.sh ]]; then
  echo "Missing scripts/start-all.sh" >&2
  exit 1
fi

if [[ -x ./scripts/start-all.sh ]]; then
  ./scripts/start-all.sh "$@"
else
  bash ./scripts/start-all.sh "$@"
fi
